# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=-100xxxxxxxxxx  # Group chat ID where news will be broadcast
ADMIN_USER_ID=your_telegram_user_id_here  # Your numeric Telegram User ID (e.g. 123456789)

# Optional Topic/Thread IDs for Forums (Leave blank to broadcast to main group chat)
THREAD_ID_ARSENAL=
THREAD_ID_LIVERPOOL=
THREAD_ID_INTER=
THREAD_ID_GENERAL=

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash  # Optional. Defaults to gemini-2.0-flash. Other options: gemini-2.5-flash, gemini-2.5-pro

# Optional X/Twitter Credentials for Twikit Ingest
X_USERNAME=your_x_username_here
X_PASSWORD=your_x_password_here
X_EMAIL=your_x_email_here

# Optional Proxy Configuration for Twikit (HTTP/SOCKS5)
# Example: http://username:password@12.34.56.78:8080 or socks5://12.34.56.78:1080
PROXY_URL=

# Include retweets from monitored X accounts (default true). Curator/aggregator accounts
# mostly retweet; when on, the original tweet's full text is posted and de-duplicated by
# the original tweet id. Set to false to only post accounts' own original tweets.
X_INCLUDE_RETWEETS=true

# TikTok Monitor (optional). Downloads new videos from monitored creators and posts
# them natively (autoplay) to Telegram. Requires yt-dlp + ffmpeg (see README).
# Leave TIKTOK_CHAT_ID blank to use the main TELEGRAM_CHAT_ID.
# Set TIKTOK_THREAD_ID to the topic/thread ID of a "TikTok" forum topic in the group.
TIKTOK_CHAT_ID=
TIKTOK_THREAD_ID=

# Residential scraping proxy for sites that block the datacenter IP (Reach plc / CloudFront).
# Only PROXY_DOMAINS are routed through it, HTTP-only, to keep proxy data low.
# Example: http://user:pass@geo.iproyal.com:12321
SCRAPER_PROXY_URL=
PROXY_DOMAINS=mirror.co.uk,liverpoolecho.co.uk,football.london,givemesport.com,thesun.co.uk,telegraph.co.uk,thetimes.com
PROXY_IMPERSONATE=chrome131
PROXY_MIN_INTERVAL_SECONDS=1200
